# ============================================
# Backend (Express) - Environment Variables
# --------------------------------------------
# Copy this file to `.env` and fill in real values:
#   Copy-Item .env.example .env   (PowerShell)
# `.env` is the only file loaded at runtime.
# ============================================

# --- Server ---
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed origins for CORS. Must be exact
# matches (scheme + host + port). Credentials are enabled, so `*`
# will NOT work.
CORS_ORIGINS=http://localhost:3000

# --- MongoDB ---
MONGO_URI=mongodb://127.0.0.1:27017/ai_gateway

# --- JWT / Auth ---
# Use long random strings (>= 32 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ACCESS_TOKEN_SECRET=replace_me_with_a_long_random_string
REFRESH_TOKEN_SECRET=replace_me_with_another_long_random_string
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Cookie behaviour. Keep `secure=true` + SameSite=Strict in production;
# set `secure=false` only for plain-HTTP local dev.
COOKIE_SECURE=false
COOKIE_SAMESITE=strict

# --- Python AI Service ---
AI_SERVICE_URL=http://127.0.0.1:8000
AI_SERVICE_TIMEOUT_MS=60000
# Retry config for transient errors / cold starts on the AI service.
AI_SERVICE_RETRIES=3
AI_SERVICE_RETRY_DELAY_MS=500

# --- LLM Provider Keys ---
# These keys are *consumed by the Python AI service*, not by Node, but
# they are listed here so the team has one canonical env reference.
# Live values must live in `ai-service/.env`.
#   GROQ_API_KEY   — default chat provider (https://console.groq.com/keys)
#   GEMINI_API_KEY — used when the frontend toggles "use Gemini"
