# ============================================
# AI Service - Environment Variables TEMPLATE
# --------------------------------------------
# This file documents the variables the service
# reads at startup. To use it:
#
#     cp .env.example .env          (on *nix / WSL)
#     Copy-Item .env.example .env   (on PowerShell)
#
# then fill in your real credentials in `.env`.
# `.env` is the ONLY file the service loads at
# runtime — `.env.example` is never read.
# ============================================

# --- Groq (DEFAULT chat provider) ---
# Sign up at https://console.groq.com/keys to grab a key.
GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Google Gemini (toggle via `use_gemini=true` in chat requests) ---
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash-lite

# --- Embeddings (LOCAL — no key required) ---
# Default: `sentence-transformers/all-MiniLM-L6-v2`. The first request
# downloads ~90 MB into your HuggingFace cache; subsequent runs are
# instant and fully offline.
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Runtime ---
# APP_ENV=development
# LOG_LEVEL=INFO

# --- Storage ---
# Override the default vector-store location if you want.
# VECTOR_STORE_DIR=./storage/vectors
